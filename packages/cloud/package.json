{
  "name": "@melaka/cloud",
  "version": "0.1.0",
  "description": "Melaka Cloud - Fully managed translation service",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dashboard": {
      "import": "./dist/dashboard.js",
      "types": "./dist/dashboard.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/dashboard.ts --format esm --dts",
    "dev": "tsup src/index.ts src/dashboard.ts --format esm --dts --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@melaka/ai": "workspace:*",
    "@melaka/core": "workspace:*",
    "@google-cloud/tasks": "^5.0.0",
    "@supabase/supabase-js": "^2.98.0",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^9.0.0",
    "ioredis": "^5.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
